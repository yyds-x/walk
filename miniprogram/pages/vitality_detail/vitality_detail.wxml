<view class="page">
  <view class="nav">
    <view class="nav-left" bindtap="handleBack">
      <text class="back">‹</text>
    </view>
    <view class="nav-title">活力值明细</view>
    <view class="nav-right"></view>
  </view>

  <view class="list">
    <block wx:for="{{items}}" wx:key="id">
      <view class="item">
        <view class="item-left">
          <text class="item-title">{{item.title}}</text>
          <text class="item-sub">{{item.sub}}</text>
        </view>
        <text class="item-amount {{item.amount > 0 ? 'plus' : 'minus'}}">{{item.amount > 0 ? '+' : ''}}{{item.amount}}</text>
      </view>
    </block>

    <view class="empty" wx:if="{{!items.length && !isLoading}}">
      <text class="empty-text">暂无明细</text>
    </view>

    <view class="loading" wx:if="{{isLoading}}">
      <text class="loading-text">加载中...</text>
    </view>

    <view class="nomore" wx:if="{{!hasMore && items.length}}">
      <text class="nomore-text">没有更多了</text>
    </view>
  </view>
</view>

