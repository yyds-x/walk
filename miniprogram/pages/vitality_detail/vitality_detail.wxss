.page {
  min-height: 100vh;
  background: #f5f7fa;
}

.nav {
  background: #f5f7fa;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-left {
  width: 88rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.back {
  font-size: 44rpx;
  color: #111;
  line-height: 1;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111;
}

.nav-right {
  width: 160rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 14rpx;
}

.nav-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 18rpx rgba(15, 23, 42, 0.06);
}

.nav-icon-share {
  padding: 0;
  line-height: 56rpx;
  border: 0;
}

.nav-icon-share::after {
  border: 0;
}

.nav-dots {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.nav-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #111;
}

.nav-share-plus {
  width: 34rpx;
  height: 34rpx;
  border-radius: 999rpx;
  border: 2rpx solid #111;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #111;
  line-height: 1;
}

.hero {
  padding: 12rpx 24rpx 0;
  box-sizing: border-box;
}

.hero-card {
  background: #eafff0;
  border-radius: 24rpx;
  height: 290rpx;
  padding: 26rpx 24rpx 24rpx;
  position: relative;
  overflow: hidden;
}

.hero-card::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  opacity: 0.11;
  background-image: linear-gradient(186.11deg, #54fb9e -52.25%, #12da66 102.69%);
  z-index: 0;
}

.hero-bg {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 2;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.metrics {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.metric {
  flex: 1;
  min-width: 0;
}

.metric-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.metric-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: #fbbf24;
  box-shadow: 0 6rpx 14rpx rgba(251, 191, 36, 0.35);
}

.metric-name {
  font-size: 24rpx;
  color: rgba(17, 17, 17, 0.6);
}

.metric-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #111;
  letter-spacing: 1rpx;
}

.metric-divider {
  width: 2rpx;
  height: 72rpx;
  background: rgba(17, 17, 17, 0.08);
  margin: 0 18rpx;
  border-radius: 999rpx;
}

.hero-btn-wrap {
  margin-top: 20rpx;
  position: relative;
  display: flex;
  justify-content: center;
}

.hero-btn-shadow {
  position: absolute;
  width: 520rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: rgba(245, 158, 11, 0.35);
  transform: translateY(12rpx);
  filter: blur(12rpx);
}

.hero-btn {
  width: 520rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #fbbf24 0%, #f59e0b 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: 0;
  box-shadow: 0 18rpx 32rpx rgba(245, 158, 11, 0.28);
}

.hero-btn::after {
  border: 0;
}

.hero-btn-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #5a3b00;
}

.ledger {
  padding: 18rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.ledger-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.05);
}

.row {
  padding: 26rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.row-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.row-title {
  font-size: 30rpx;
  color: #111;
  font-weight: 700;
}

.row-date {
  font-size: 22rpx;
  color: #888;
}

.row-amount {
  font-size: 32rpx;
  font-weight: 800;
}

.row-amount.plus {
  color: #16a34a;
}

.row-amount.minus {
  color: #f97316;
}

.row-divider {
  height: 2rpx;
  background: rgba(15, 23, 42, 0.06);
  margin: 0 24rpx;
}

.empty,
.loading,
.nomore {
  padding: 40rpx 0;
  display: flex;
  justify-content: center;
}

.empty-text,
.loading-text,
.nomore-text {
  font-size: 24rpx;
  color: #999;
}
