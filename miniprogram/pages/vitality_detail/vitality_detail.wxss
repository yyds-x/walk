.page {
  min-height: 100vh;
  background: #F8F9FC;
}

.hero {
  padding: 12rpx 30rpx 0;
  box-sizing: border-box;
  position: relative;
}

.hero-glow {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: -12rpx;
  height: 24rpx;
  background: #53D639;
  opacity: 0.44;
  filter: blur(24px);
  border-radius: 24rpx;
}

.hero-card {
  background: linear-gradient(183deg, rgba(84, 251, 158, 1) 0%, rgba(18, 218, 102, 1) 100%);
  border-radius: 24rpx;
  height: 290rpx;
  padding: 0;
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 2;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 36rpx 30rpx 0;
  box-sizing: border-box;
}

/* 数据区 */
.metrics {
  display: flex;
  align-items: flex-start;
}

.metric {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.metric-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.metric-icon {
  width: 34rpx;
  height: 34rpx;
}

.metric-name {
  font-size: 24rpx;
  color: #121834;
  opacity: 0.4;
  font-family: "PingFang SC", sans-serif;
  font-weight: 400;
}

.metric-value {
  font-size: 40rpx;
  font-weight: 400;
  color: #121834;
  font-family: "DIN", "DIN Alternate", "Helvetica Neue", sans-serif;
  letter-spacing: 1rpx;
}

.metric-divider {
  width: 1rpx;
  height: 36rpx;
  background: #B1B9B4;
  margin: 10rpx 0 0;
  opacity: 0.5;
}

/* 推荐按钮 */
.hero-btn-wrap {
  display: flex;
  justify-content: center;
  padding-bottom: 24rpx;
}

.hero-btn {
  width: 396rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: linear-gradient(0deg, #FF9F00 0%, #FFF400 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 0;
  border: 0;
  box-shadow: 0 4rpx 0 0 #F29929, inset 0 -2rpx 10rpx 0 rgba(255, 244, 70, 1);
}

.hero-btn::after {
  border: 0;
}

.hero-btn-icon {
  width: 36rpx;
  height: 36rpx;
}

.hero-btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #754A00;
  font-family: "PingFang SC", sans-serif;
}

/* ===== 明细列表 ===== */
.ledger {
  padding: 24rpx 30rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.ledger-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
}

.row {
  padding: 26rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.row-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.row-title {
  font-size: 30rpx;
  color: #121834;
  font-weight: 500;
  font-family: "PingFang SC", sans-serif;
}

.row-date {
  font-size: 24rpx;
  color: #A2B0B8;
  font-family: "PingFang SC", sans-serif;
  font-weight: 400;
}

.row-amount {
  font-size: 36rpx;
  font-weight: 500;
  font-family: "PingFang SC", sans-serif;
}

.row-amount.plus {
  color: #00C757;
}

.row-amount.minus {
  color: #FA6400;
}

.row-divider {
  height: 1rpx;
  background: #EDEDED;
  margin: 0 32rpx;
}

/* 空状态 / 加载 / 没有更多 */
.empty,
.loading,
.nomore {
  padding: 40rpx 0;
  display: flex;
  justify-content: center;
}

.empty-text,
.loading-text {
  font-size: 24rpx;
  color: #A2B0B8;
}

.nomore-text {
  font-size: 26rpx;
  color: #A2B0B8;
  font-family: "PingFang SC", sans-serif;
  font-weight: 400;
}
