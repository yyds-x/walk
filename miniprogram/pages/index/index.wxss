page {
  box-sizing: border-box;
}

.frame120 {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  background: #ffffff;
  padding-bottom: 0rpx;
  width: 750rpx; /* 375px * 2 */
  overflow: hidden;
  box-sizing: border-box;
}

/* Hero Banner */
.frame48 {
  position: relative;
  left: 30rpx; /* 15px * 2 */
  width: 690rpx; /* 345px * 2 */
  height: 300rpx; /* 150px * 2 */
  margin-top: 20rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.frame48-bg {
  width: 100%;
  height: 100%;
  display: block;
}

/* Feature Icons Grid */
.autoWrapper14 {
  display: flex;
  align-items: center;
  align-self: stretch;
  justify-content: space-between;
  margin-top: 20rpx; /* Reduced from 168rpx */
  padding: 0 52rpx;
}

.autoWrapper8, .autoWrapper9, .autoWrapper10, .autoWrapper11, .autoWrapper13 {
  position: relative;
  width: 88rpx;
  height: 88rpx;
}

.full-icon {
  width: 100%;
  height: 100%;
  display: block;
}

/* Feature Labels */
.autoWrapper15 {
  display: flex;
  align-items: center;
  align-self: stretch;
  margin-top: 16rpx;
  padding: 0 52rpx;
  justify-content: space-between;
}

.text2, .text3, .text4, .text5 {
  line-height: 34rpx;
  letter-spacing: 0;
  color: #474c62;
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", SimHei, Arial, Helvetica, sans-serif;
  font-size: 24rpx;
  width: 88rpx;
  text-align: center;
  white-space: nowrap;
}

/* Task Banner */
