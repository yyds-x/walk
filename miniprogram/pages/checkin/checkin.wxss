.page {
  position: relative;
  min-height: 100vh;
  background: #f8f9fc;
  overflow: hidden;
}

.bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 750rpx;
  height: 484rpx;
  background: linear-gradient(180deg, #3b3f4f 0%, #2b2f3b 100%);
  z-index: 1;
}

.bg::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 750rpx;
  height: 484rpx;
  background: radial-gradient(circle at 75% 20%, rgba(0, 199, 87, 0.22) 0%, rgba(0, 199, 87, 0) 55%);
}

.bubble {
  position: absolute;
  opacity: 0.28;
}

.bubble-big {
  width: 302rpx;
  height: 304rpx;
  right: -64rpx;
  top: 56rpx;
}

.bubble-small {
  width: 182rpx;
  height: 184rpx;
  left: -40rpx;
  top: 120rpx;
}

.bg-inner {
  position: relative;
  z-index: 2;
  padding: 24rpx 30rpx 0;
  box-sizing: border-box;
}

.nav-row {
  height: 88rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  width: 80rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 44rpx;
  color: #ffffff;
  line-height: 1;
}

.user-row {
  display: flex;
  align-items: center;
  padding: 0 0 0 0;
  margin-top: 24rpx;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
}

.user-meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  margin-left: 32rpx;
}

.streak-title {
  line-height: 44rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
}

.streak-sub {
  margin-top: 10rpx;
  line-height: 34rpx;
  color: #d4d4d4;
  font-size: 24rpx;
}

.balance {
  margin-left: 112rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 38rpx;
  background: rgba(255, 255, 255, 0.14);
  padding: 14rpx 26rpx 14rpx 22rpx;
  width: 182rpx;
  height: 76rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.balance-icon {
  width: 44rpx;
  height: 44rpx;
}

.balance-num {
  line-height: 44rpx;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 500;
}

.sign-card {
  position: absolute;
  top: 336rpx;
  left: 30rpx;
  width: 690rpx;
  height: 660rpx;
  border-radius: 24rpx;
  background: #ffffff;
  padding: 32rpx 32rpx 48rpx;
  box-sizing: border-box;
  z-index: 2;
}

.sign-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sign-title {
  line-height: 44rpx;
  color: #121834;
  font-size: 32rpx;
  font-weight: 500;
}

.sign-rule {
  line-height: 40rpx;
  color: #00c757;
  font-size: 28rpx;
}

.sign-days {
  margin-top: 36rpx;
}

.sign-days-top {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.sign-days-bottom {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-top: 28rpx;
}

.day-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  border-radius: 16rpx;
  background: #f7f6f9;
  padding: 16rpx 22rpx 18rpx 24rpx;
  box-sizing: border-box;
  width: 140rpx;
}

.day-item.done {
  box-shadow: 0 12rpx 20rpx rgba(25, 196, 16, 0.24);
  background-image: linear-gradient(201.18deg, #6dd400 -31.95%, #00c757 104.14%);
}

.day-item.done .day-title,
.day-item.done .day-reward {
  color: #ffffff;
}

.day-item.active {
  background: #ecfff4;
  box-shadow: 0 10rpx 18rpx rgba(25, 196, 16, 0.14);
  border: 2rpx solid rgba(0, 199, 87, 0.6);
}

.day-item.active .day-reward {
  color: rgba(0, 199, 87, 0.9);
}

.day-title {
  line-height: 40rpx;
  color: #121834;
  font-size: 28rpx;
  font-weight: 500;
}

.day-icon {
  margin-top: 16rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.day-check {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
}

.day-gift {
  width: 56rpx;
  height: 56rpx;
}

.day-coin {
  width: 56rpx;
  height: 56rpx;
}

.day-reward {
  margin-top: 16rpx;
  line-height: 30rpx;
  color: #a2b0b8;
  font-size: 22rpx;
}

.btn-wrap {
  position: relative;
  margin: 48rpx auto 0;
  width: 570rpx;
  height: 88rpx;
}

.btn-shadow {
  position: absolute;
  bottom: -4rpx;
  left: 50%;
  opacity: 0.51;
  background: #53d639;
  width: 522rpx;
  height: 28rpx;
  filter: blur(10rpx);
  transform: translateX(-50%);
}

.btn {
  position: absolute;
  top: 0;
  left: 0;
  width: 570rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: #0da24e;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn.disabled {
  background: #d0d0d0;
}

.btn-text {
  position: relative;
  z-index: 1;
  line-height: 44rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
}

.btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: linear-gradient(253.8deg, #6dd400 88.24%, #00c757 171.93%);
}

.btn.disabled::before {
  background-image: none;
}

.btn.disabled .btn-text {
  color: #ffffff;
}

.content {
  background: #f8f9fc;
  padding: 1024rpx 30rpx 152rpx;
  box-sizing: border-box;
  min-height: 100vh;
  position: relative;
  z-index: 0;
}

.entry-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-radius: 24rpx;
  background: #ffffff;
  padding: 30rpx 32rpx;
}

.entry-left {
  display: flex;
  align-items: center;
}

.entry-icon-wrap {
  display: flex;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 8rpx;
}

.entry-icon {
  width: 24rpx;
  height: 30rpx;
  border: 2rpx solid rgba(18, 24, 52, 0.35);
  border-radius: 6rpx;
  position: relative;
  box-sizing: border-box;
}

.entry-icon::after {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 4rpx;
  width: 14rpx;
  height: 2rpx;
  background: rgba(18, 24, 52, 0.25);
}

.entry-text {
  margin-left: 8rpx;
  line-height: 40rpx;
  color: #121834;
  font-size: 28rpx;
}

.entry-arrow {
  width: 24rpx;
  height: 32rpx;
}

.tasks-card {
  margin-top: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  padding: 32rpx;
  box-sizing: border-box;
}

.tasks-title {
  line-height: 44rpx;
  color: #121834;
  font-size: 32rpx;
  font-weight: 500;
}

.task-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 36rpx;
}

.task-row.mt-24 {
  margin-top: 48rpx;
}

.task-left {
  display: flex;
  align-items: center;
  min-width: 0;
}

.task-badge {
  position: relative;
  width: 84rpx;
  height: 84rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.task-badge::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 84rpx;
  height: 84rpx;
  opacity: 0.55;
  border-radius: 50%;
}

.task-blue::before {
  background: #0091ff;
}

.task-green::before {
  background: #00c757;
}

.task-red::before {
  background: #ff5f6a;
}

.task-badge-icon {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  margin: auto;
  width: 84rpx;
  height: 84rpx;
}

.task-text {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  align-self: stretch;
  margin-left: 24rpx;
  min-width: 0;
}

.task-name {
  line-height: 40rpx;
  color: #121834;
  font-size: 28rpx;
  font-weight: 500;
}

.task-desc {
  margin-top: 6rpx;
  line-height: 34rpx;
  color: #a2b0b8;
  font-size: 24rpx;
}

.task-pill {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  border-radius: 28rpx;
  box-shadow: 0 10rpx 18rpx rgba(75, 181, 4, 0.24);
  padding: 8rpx 24rpx 12rpx;
  width: 146rpx;
  min-width: 146rpx;
  background-image: linear-gradient(90.87deg, #15ca46 0.46%, #65d307 98.06%);
  box-sizing: border-box;
}

.pill-icon {
  margin-top: 6rpx;
  width: 28rpx;
  height: 28rpx;
}

.pill-text {
  line-height: 36rpx;
  color: #ffffff;
  font-size: 26rpx;
}
