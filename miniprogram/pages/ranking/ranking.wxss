.page {
  min-height: 100vh;
  background: #11D267;
}

/* ===== 顶部 Hero 区域 ===== */
.hero {
  position: relative;
  height: 680rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.hero-bg-img {
  width: 100%;
  height: 100%;
}

.hero-content {
  position: relative;
  z-index: 2;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-title {
  font-family: "PingFang SC", sans-serif;
  font-weight: 700;
  font-size: 84rpx;
  color: #FFFFFF;
  letter-spacing: 12rpx;
  margin-top: 40rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.15);
}

/* ===== 领奖台 ===== */
.podium {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  width: 100%;
  padding: 0 40rpx;
  box-sizing: border-box;
  margin-top: auto;
  padding-bottom: 20rpx;
}

.podium-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 200rpx;
}

.podium-item.first {
  margin: 0 10rpx;
}

.podium-avatar-wrap {
  position: relative;
  margin-bottom: 12rpx;
}

.crown-icon {
  width: 50rpx;
  height: 40rpx;
  margin-bottom: 4rpx;
}

.podium-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
}

.podium-avatar-first {
  width: 100rpx;
  height: 100rpx;
}

.podium-badge {
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 700;
  color: #fff;
  font-family: "DIN", sans-serif;
}

.badge-gold {
  background: linear-gradient(180deg, #FFE303 0%, #FA6400 100%);
  box-shadow: inset 0 2rpx 4rpx rgba(255, 236, 178, 1);
}

.badge-silver {
  background: linear-gradient(180deg, #E4B0FF 0%, #B336FF 100%);
  box-shadow: inset 0 2rpx 4rpx rgba(231, 189, 255, 1);
}

.badge-bronze {
  background: linear-gradient(0deg, #CBC9C9 0%, #E9E9E9 100%);
  box-shadow: inset 0 2rpx 6rpx rgba(255, 255, 255, 0.5);
  color: #666;
}

.podium-name {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 10rpx;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.podium-bar {
  width: 120rpx;
  border-radius: 12rpx 12rpx 0 0;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 16rpx;
  box-sizing: border-box;
}

.bar-first {
  height: 180rpx;
  background: linear-gradient(180deg, rgba(40, 194, 249, 1) 0%, rgba(28, 164, 213, 1) 100%);
  box-shadow: inset 2rpx 0 4rpx rgba(132, 223, 255, 1);
}

.bar-second {
  height: 130rpx;
  background: linear-gradient(180deg, rgba(40, 194, 249, 0.9) 0%, rgba(28, 164, 213, 0.9) 100%);
  box-shadow: inset 2rpx 0 4rpx rgba(33, 175, 227, 1);
}

.bar-third {
  height: 100rpx;
  background: linear-gradient(180deg, rgba(40, 194, 249, 0.85) 0%, rgba(28, 164, 213, 0.85) 100%);
  box-shadow: inset -2rpx 0 4rpx rgba(132, 223, 255, 1);
}

.podium-score {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

/* ===== 绿色分割条 ===== */
.green-divider {
  height: 40rpx;
  background: #11D267;
  box-shadow: 0 2rpx 4rpx rgba(18, 192, 85, 1);
  border-radius: 36rpx;
  margin: -20rpx 12rpx 0;
  position: relative;
  z-index: 3;
}

/* ===== 排行列表 ===== */
.list-wrap {
  padding: 0 40rpx calc(32rpx + env(safe-area-inset-bottom));
  margin-top: -10rpx;
  position: relative;
  z-index: 2;
}

.list-card {
  background: linear-gradient(180deg, rgba(157, 242, 194, 1) 0%, rgba(255, 255, 255, 1) 4%);
  border-radius: 24rpx;
  padding: 20rpx 0 10rpx;
  overflow: hidden;
}

/* 表头 */
.list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx 16rpx;
}

.header-rank {
  font-size: 28rpx;
  color: #A2B0B8;
  font-weight: 400;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.header-icon {
  width: 36rpx;
  height: 36rpx;
}

.header-score {
  font-size: 28rpx;
  color: #A2B0B8;
  font-weight: 400;
}

/* 列表行 */
.list-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 32rpx;
}

.row-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  flex: 1;
}

.medal-icon {
  width: 52rpx;
  height: 66rpx;
  flex-shrink: 0;
}

.rank-num {
  width: 52rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 400;
  color: #121834;
  font-family: "DIN", "DIN Alternate", sans-serif;
  flex-shrink: 0;
}

.list-avatar {
  width: 74rpx;
  height: 74rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.list-name {
  font-size: 30rpx;
  color: #121834;
  font-weight: 400;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.list-score {
  font-size: 36rpx;
  font-weight: 500;
  color: #00C757;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 空状态 / 加载 */
.empty,
.loading {
  padding: 60rpx 0;
  display: flex;
  justify-content: center;
}

.empty-text,
.loading-text {
  font-size: 26rpx;
  color: #A2B0B8;
}
