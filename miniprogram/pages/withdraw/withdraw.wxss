.page {
  min-height: 100vh;
  background: #F5F5F5;
}

/* ===== Header ===== */
.header {
  background: linear-gradient(180deg, #00C757 0%, #4CD964 100%);
  padding: 40rpx 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.balance-row {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.balance-center {
  display: flex;
  align-items: baseline;
}

.balance-amount {
  font-family: "DIN", "DIN Alternate", sans-serif;
  font-size: 80rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.balance-unit {
  font-size: 32rpx;
  color: #FFFFFF;
  margin-left: 8rpx;
  font-weight: 500;
}

.history-btn {
  position: absolute;
  right: 0;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 24rpx;
  padding: 8rpx 24rpx;
}

.history-text {
  font-size: 24rpx;
  color: #FFFFFF;
}

.balance-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

/* ===== Card ===== */
.card {
  margin: -40rpx 32rpx 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx;
  position: relative;
  z-index: 2;
}

.card-title-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 32rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #121834;
}

.card-hint {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

/* Input row */
.input-row {
  display: flex;
  align-items: center;
  padding-bottom: 20rpx;
}

.yen-sign {
  font-size: 40rpx;
  font-weight: 600;
  color: #121834;
  margin-right: 16rpx;
}

.amount-input {
  flex: 1;
  font-size: 32rpx;
  color: #121834;
  height: 60rpx;
}

.input-placeholder {
  color: #C8C8C8;
  font-size: 30rpx;
}

.all-btn {
  border: 2rpx solid #DCDCDC;
  border-radius: 28rpx;
  padding: 8rpx 28rpx;
  margin-left: 16rpx;
}

.all-btn-text {
  font-size: 26rpx;
  color: #666;
}

.input-line {
  height: 2rpx;
  background: #EEEEEE;
  margin-bottom: 40rpx;
}

/* Withdraw button */
.withdraw-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #4CD964 0%, #00C757 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.withdraw-btn.disabled {
  opacity: 0.5;
}

.withdraw-btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* Invite button */
.invite-btn {
  width: 100%;
  height: 96rpx;
  border: 2rpx solid #00C757;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.invite-icon {
  font-size: 36rpx;
}

.invite-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #00C757;
}

/* ===== Instructions ===== */
.instructions {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
}

.instructions-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #121834;
  margin-bottom: 20rpx;
}

.instructions-item {
  font-size: 26rpx;
  color: #999;
  line-height: 1.8;
}
