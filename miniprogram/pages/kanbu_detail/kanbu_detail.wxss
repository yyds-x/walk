.page {
  background: #F8F9FC;
  min-height: 100vh;
  position: relative;
}

/* Nav Bar */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
}
.nav-bar-inner {
  position: relative;
}
.back-btn {
  position: absolute;
  left: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.05);
}
.back-icon {
  width: 36rpx;
  height: 36rpx;
}

/* Content */
.content {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
}

/* Product Image */
.product-image-section {
  position: relative;
  width: 100%;
  height: 500rpx;
  background: #fff;
}
.product-swiper {
  width: 100%;
  height: 100%;
}
.product-img {
  width: 100%;
  height: 100%;
}
.image-indicator {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  background: #121834;
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* Product Info Card */
.product-info-card {
  background: #fff;
  padding: 24rpx 30rpx;
}
.product-name {
  font-size: 36rpx;
  font-weight: 500;
  color: #121834;
  line-height: 1.4;
  margin-bottom: 16rpx;
}
.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}
.vitality-price {
  font-size: 36rpx;
  font-weight: 500;
  color: #00C757;
  margin-right: 16rpx;
}
.original-price {
  font-size: 24rpx;
  color: #A2B0B8;
  text-decoration: line-through;
  margin-right: 16rpx;
}
.remaining {
  font-size: 24rpx;
  color: #A2B0B8;
}
.activity-hint {
  display: flex;
  align-items: center;
}
.activity-text {
  font-size: 24rpx;
  color: #A2B0B8;
}
.info-icon {
  width: 24rpx;
  height: 24rpx;
  margin-left: 8rpx;
  opacity: 0.4;
  transform: rotate(180deg);
}

/* Section Divider */
.section-divider {
  height: 20rpx;
  background: #F8F9FC;
}

/* Lucky Section */
.lucky-section {
  background: #fff;
  padding: 30rpx;
}
.lucky-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #121834;
  text-align: center;
  margin-bottom: 24rpx;
}

/* Countdown */
.countdown-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}
.countdown-label {
  font-size: 24rpx;
  color: #A2B0B8;
  margin: 0 8rpx;
}
.time-block {
  width: 48rpx;
  height: 48rpx;
  background: #121834;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.time-num {
  font-size: 28rpx;
  font-weight: 500;
  color: #fff;
}
.time-colon {
  font-size: 28rpx;
  font-weight: 500;
  color: #121834;
  margin: 0 4rpx;
}

/* Progress Bar */
.progress-section {
  padding: 60rpx 20rpx 40rpx;
}
.progress-bar-bg {
  position: relative;
  height: 16rpx;
  background: #EFF0F4;
  border-radius: 8rpx;
}
.progress-bar-fill {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  background: #00C857;
  border-radius: 8rpx;
  transition: width 0.3s;
}

/* Milestones */
.milestone {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}
.milestone-1 { left: 33.3%; }
.milestone-2 { left: 66.6%; }
.milestone-3 { left: 100%; }

.milestone-icon {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.4;
}
.milestone.active .milestone-icon {
  opacity: 1;
}
.milestone-label {
  font-size: 20rpx;
  color: #A2B0B8;
  margin-top: 8rpx;
  white-space: nowrap;
}
.milestone.active .milestone-label {
  color: #00C757;
}

/* Steps Info */
.steps-info-row {
  display: flex;
  justify-content: space-between;
  padding: 0 20rpx;
}
.steps-info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.steps-info-label {
  font-size: 24rpx;
  color: #A2B0B8;
  margin-bottom: 4rpx;
}
.steps-info-value {
  font-size: 24rpx;
  color: #121834;
  font-weight: 500;
}

/* Records Section */
.records-section {
  background: #fff;
  padding: 30rpx;
}
.records-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.records-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #121834;
}
.records-all {
  display: flex;
  align-items: center;
}
.records-all-text {
  font-size: 24rpx;
  color: #A2B0B8;
}
.arrow-icon {
  width: 24rpx;
  height: 24rpx;
  transform: rotate(180deg);
  opacity: 0.4;
}
.record-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}
.record-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #EFF0F4;
}
.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.record-name {
  font-size: 28rpx;
  color: #121834;
  margin-bottom: 4rpx;
}
.record-time {
  font-size: 22rpx;
  color: #A2B0B8;
}
.record-steps {
  font-size: 28rpx;
  color: #00C757;
  font-weight: 500;
}

/* Bottom */
.bottom-space {
  height: 160rpx;
}
.bottom-btn-wrapper {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 30rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
}
.bottom-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #00C757, #0DA24E);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.bottom-btn-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
}
