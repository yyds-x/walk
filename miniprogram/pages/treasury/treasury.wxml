<scroll-view class="page" type="list" scroll-y>
  <view class="header">
    <view class="nav" style="padding-top: {{statusBarHeight}}px;">
      <view class="nav-row">
        <view class="nav-left" bindtap="handleBack">
          <text class="nav-back">‹</text>
        </view>
        <text class="nav-title">我的金库</text>
        <view class="nav-right">
          <view class="nav-capsule">
            <image class="nav-more" src="/images/home/gengduo.svg" mode="aspectFit"></image>
            <view class="nav-dot"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="income-card">
      <view class="income-left">
        <text class="income-label">今日收益</text>
        <view class="income-amount-row">
          <text class="income-amount">{{todayIncome}}</text>
          <text class="income-unit">元</text>
        </view>
        <text class="income-total">累计收益：{{totalIncome}}元</text>
      </view>
      <view class="income-right">
        <image class="income-avatar" src="{{avatarUrl}}" mode="aspectFill"></image>
        <view class="income-info" bindtap="handleActivityInfo">
          <text class="income-info-icon">i</text>
          <text class="income-info-text">活动说明</text>
        </view>
      </view>
    </view>
  </view>

  <view class="stats">
    <view class="stat">
      <text class="stat-num">{{teamCount}}</text>
      <text class="stat-label">我的团队</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat">
      <text class="stat-num">{{orderCount}}</text>
      <text class="stat-label">推广订单</text>
    </view>
  </view>

  <view class="section-title">更多推广奖励</view>

  <view class="list">
    <block wx:for="{{promotions}}" wx:key="id">
      <view class="item" bindtap="handlePromoTap" data-id="{{item.id}}">
        <view class="item-left">
          <image class="item-image" src="{{item.image}}" mode="aspectFit"></image>
        </view>
        <view class="item-mid">
          <text class="item-title" overflow="ellipsis" max-lines="2">{{item.title}}</text>
          <view class="item-meta">
            <view class="earn-tag">
              <view class="earn-tag-left">
                <text class="earn-tag-text">赚</text>
              </view>
              <view class="earn-tag-right">
                <text class="earn-tag-currency">¥</text>
                <text class="earn-tag-amount">{{item.earn}}</text>
              </view>
            </view>
            <text class="item-count">{{item.promoted}}人已推广</text>
          </view>
        </view>
        <view class="item-right">
          <view class="item-btn">
            <text class="item-btn-text">立即推广</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="bottom-space"></view>
</scroll-view>
