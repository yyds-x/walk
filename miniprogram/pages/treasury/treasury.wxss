.page {
  height: 100vh;
  background: #ffffff;
}

.header {
  background-image: linear-gradient(241.93deg, #fff3fd 19.73%, #e9f1f6 123.41%);
  padding-bottom: 40rpx;
}

.nav {
  position: relative;
  padding-left: 24rpx;
  padding-right: 24rpx;
  box-sizing: border-box;
}

.nav-back-btn {
  position: absolute;
  left: 24rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-btn--light {
  background: rgba(0, 0, 0, 0.05);
}

.nav-back-icon {
  width: 36rpx;
  height: 36rpx;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 36rpx;
  font-weight: 500;
  color: #121834;
  white-space: nowrap;
}

.income-card {
  margin: 28rpx 30rpx 0;
  background: #3d435c;
  border-radius: 16rpx;
  padding: 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.income-left {
  flex: 1;
  min-width: 0;
}

.income-label {
  font-size: 24rpx;
  color: rgba(255, 228, 175, 0.8);
  line-height: 34rpx;
}

.income-amount-row {
  display: flex;
  align-items: flex-end;
  margin-top: 6rpx;
}

.income-amount {
  font-size: 56rpx;
  font-weight: 500;
  color: #ffe4af;
  line-height: 68rpx;
}

.income-unit {
  font-size: 24rpx;
  color: #ffe4af;
  margin-left: 10rpx;
  padding-bottom: 10rpx;
}

.income-total {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: rgba(255, 228, 175, 0.8);
  line-height: 34rpx;
}

.income-right {
  width: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.income-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
}

.income-info {
  display: flex;
  align-items: center;
  margin-top: 66rpx;
}

.income-info-icon {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(162, 176, 184, 1);
  color: rgba(162, 176, 184, 1);
  font-size: 18rpx;
  line-height: 22rpx;
  text-align: center;
  margin-right: 8rpx;
}

.income-info-text {
  font-size: 24rpx;
  color: rgba(162, 176, 184, 1);
  line-height: 34rpx;
}

.stats {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 160rpx 0;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 500;
  color: #8a1012;
  line-height: 58rpx;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #a2b0b8;
  line-height: 34rpx;
}

.stat-divider {
  width: 2rpx;
  height: 36rpx;
  background: #dddddd;
}

.section-title {
  margin-top: 48rpx;
  padding-left: 30rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #121834;
  line-height: 44rpx;
}

.list {
  padding: 0 30rpx;
}

.item {
  display: flex;
  align-items: center;
  padding-top: 36rpx;
}

.item-left {
  width: 148rpx;
  height: 124rpx;
  background: #ffffff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
}

.item-mid {
  flex: 1;
  min-width: 0;
}

.item-title {
  font-size: 28rpx;
  color: #121834;
  line-height: 40rpx;
}

.item-meta {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.earn-tag {
  display: flex;
  align-items: center;
  border: 2rpx solid #121734;
  border-radius: 4rpx;
  height: 32rpx;
  padding-right: 8rpx;
  margin-right: 16rpx;
}

.earn-tag-left {
  height: 32rpx;
  background: #121734;
  padding: 2rpx 8rpx 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.earn-tag-text {
  font-size: 22rpx;
  font-weight: 300;
  color: #ffdea4;
  line-height: 30rpx;
}

.earn-tag-right {
  display: flex;
  align-items: baseline;
  padding-left: 6rpx;
}

.earn-tag-currency {
  font-size: 18rpx;
  color: #121734;
  margin-right: 2rpx;
}

.earn-tag-amount {
  font-size: 22rpx;
  color: #121734;
}

.item-count {
  font-size: 22rpx;
  color: #a2b0b8;
  line-height: 30rpx;
}

.item-right {
  width: 160rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.item-btn {
  height: 64rpx;
  padding: 0 28rpx;
  border-radius: 32rpx;
  background: #3d435c;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-btn-text {
  font-size: 26rpx;
  color: #ffe4af;
  line-height: 36rpx;
}

.bottom-space {
  height: 120rpx;
}
