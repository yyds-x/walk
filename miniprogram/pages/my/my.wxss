/** index.wxss **/
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 0;
  box-sizing: border-box;
  background-color: #f5f7fa;
  position: relative;
  overflow-y: auto;
}

/* Header Background */
.header-bg {
  width: 100%;
  height: 500rpx; /* Increased height to accommodate design */
  position: absolute;
  top: 0;
  left: 0;
  z-index: 0;
}

.bg-image {
  width: 100%;
  display: block;
}

/* User Info */
.user-card {
  width: 100%;
  padding: 180rpx 40rpx 40rpx; /* Adjusted padding */
  z-index: 1;
  box-sizing: border-box;
}

.user-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.avatar-container {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  overflow: hidden;
  margin-right: 20rpx;
}

.avatar {
  width: 100%;
  height: 100%;
}

.user-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333; /* Dark text as per design on light part of bg, or need white? Design shows dark text on light part of wave */
  margin-bottom: 10rpx;
}

.user-id-badge {
  background-color: rgba(255, 255, 255, 0.5);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
  align-self: flex-start;
}

.user-id-badge text {
  font-size: 24rpx;
  color: #333;
}

.check-in-btn {
  background-color: #e0f8e9;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
}

.check-in-icon {
  margin-right: 8rpx;
  color: #00c757;
  font-size: 24rpx;
}

.check-in-btn text {
  color: #00c757;
  font-size: 24rpx;
  font-weight: 500;
}

/* Stats Card */
.stats-card {
  width: 690rpx;
  background-color: #fff;
  border-radius: 20rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 30rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  margin-top: 20rpx;
  z-index: 2;
  position: relative;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.stat-label-row {
  display: flex;
  align-items: center;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.dot.yellow { background-color: #ffc107; }
.dot.purple { background-color: #9c27b0; }
.dot.blue { background-color: #2196f3; }

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.divider {
  width: 2rpx;
  height: 40rpx;
  background-color: #eee;
}

/* Menu Grid */
.menu-grid {
  width: 690rpx;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx 0;
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.02);
}

.menu-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.menu-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 16rpx;
}

.menu-name {
  font-size: 24rpx;
  color: #666;
}

/* Banner */
.banner-section {
  width: 690rpx;
  margin-top: 20rpx;
  /* height removed to let image define height */
  position: relative;
}

.banner-content {
  width: 100%;
  border-radius: 20rpx; /* Match design curvature */
  overflow: hidden;
  box-shadow: 0 4rpx 10rpx rgba(255, 94, 98, 0.3); /* Soft colored shadow */
}

.banner-image {
  width: 100%;
  display: block; /* Remove gap */
}

/* Service Section */
.service-section {
  width: 690rpx;
  background-color: #fff;
  border-radius: 20rpx;
  margin-top: 20rpx;
  padding: 30rpx;
  box-sizing: border-box;
  margin-bottom: 40rpx;
}

.section-header {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.service-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.service-item {
  width: 48%;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.service-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
}

.service-info {
  display: flex;
  flex-direction: column;
}

.service-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.service-subtitle {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}
