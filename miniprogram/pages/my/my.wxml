<view class="container">
  <!-- Header Background -->
  <view class="header-bg">
    <image class="bg-image" src="/images/my/beijing.svg" mode="widthFix"></image>
  </view>

  <!-- User Info Section -->
  <view class="user-card">
    <view class="user-info">
      <view class="avatar-container">
        <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      </view>
      <view class="user-details">
        <text class="user-name">{{userInfo.nickName}}</text>
        <view class="user-id-badge">
          <text>ID: {{userInfo.id}}</text>
        </view>
        <view class="login-btn" bindtap="{{isLoggedIn ? 'handleLogout' : 'handleLogin'}}">
          <text class="login-icon">{{isLoggedIn ? '🔓' : '🔑'}}</text>
          <text>{{isLoggedIn ? '退出登录' : '微信登录'}}</text>
        </view>
      </view>
      <view class="check-in-btn" bindtap="handleCheckIn">
        <text class="check-in-icon">✎</text>
        <text>签到赢好礼</text>
      </view>
    </view>
  </view>

  <!-- Stats Card -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{stats.balance}}</text>
      <view class="stat-label-row">
        <view class="dot yellow"></view>
        <text class="stat-label">活力值余额</text>
      </view>
    </view>
    <view class="divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.income}}</text>
      <view class="stat-label-row">
        <view class="dot purple"></view>
        <text class="stat-label">我的收益</text>
      </view>
    </view>
    <view class="divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.inviteCount}}</text>
      <view class="stat-label-row">
        <view class="dot blue"></view>
        <text class="stat-label">邀请好友数</text>
      </view>
    </view>
  </view>

  <!-- Menu Grid -->
  <view class="menu-grid">
    <block wx:for="{{menuItems}}" wx:key="id">
      <view class="menu-item" bindtap="handleMenuClick" data-item="{{item}}">
        <image class="menu-icon" src="{{item.icon}}" mode="aspectFit"></image>
        <text class="menu-name">{{item.name}}</text>
      </view>
    </block>
  </view>

  <!-- Banner -->
  <view class="banner-section">
    <view class="banner-content">
      <image class="banner-image" src="/images/my/banner.svg" mode="widthFix"></image>
    </view>
  </view>

  <!-- V Alliance Services -->
  <view class="service-section">
    <view class="section-header">
      <text class="section-title">V联盟服务</text>
    </view>
    <view class="service-grid">
      <block wx:for="{{services}}" wx:key="id">
        <view class="service-item">
          <image class="service-icon" src="{{item.icon}}" mode="aspectFit"></image>
          <view class="service-info">
            <text class="service-title">{{item.title}}</text>
            <text class="service-subtitle">{{item.subtitle}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="spacer" style="height: 100rpx;"></view>
</view>
