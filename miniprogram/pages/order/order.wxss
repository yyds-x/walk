/** order.wxss **/
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f7fa;
  padding: 0;
}

/* Tabs */
.tabs {
  display: flex;
  background-color: #fff;
  padding: 20rpx 0 0;
  border-bottom: none;
  position: sticky;
  top: 0;
  z-index: 10;
  width: 100%;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  padding-bottom: 20rpx;
}

.tab-text {
  font-size: 28rpx;
  color: #a2b0b8; /* Gray for inactive */
  line-height: 40rpx;
}

.tab-item.active .tab-text {
  color: #121834; /* Dark blue for active */
  font-weight: 500; /* Medium bold */
  font-size: 30rpx; /* Adjusted to be closer to 15px/design */
}

.tab-indicator {
  width: 56rpx; /* 28px */
  height: 6rpx; /* 3px */
  background-color: #00c757; /* Green accent */
  border-radius: 4rpx;
  position: absolute;
  bottom: 10rpx; /* Positioned inside padding */
}

/* Order List */
.order-list {
  flex: 1;
  padding: 20rpx 30rpx;
  box-sizing: border-box;
}

.order-card {
  background-color: #fff;
  border-radius: 24rpx; /* 12px */
  padding: 28rpx 32rpx; /* 14px 16px */
  margin-bottom: 28rpx; /* 14px */
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
}

/* Card Header */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 28rpx; /* 14px */
}

.order-info {
  display: flex;
  flex-direction: column;
}

.order-no {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.order-date {
  font-size: 24rpx; /* 12px */
  color: #a2b0b8;
}

.order-status {
  font-size: 28rpx; /* 14px */
  color: #00c757;
  font-weight: 500;
}

/* Product Section */
.product-container {
  background-color: #f7f8fa; /* Light gray from design frame17/bg */
  border-radius: 12rpx;
  padding: 16rpx;
  display: flex;
  align-items: center;
  min-height: 180rpx; /* 90px */
}

.product-image {
  width: 140rpx; /* 70px */
  height: 140rpx; /* 70px */
  border-radius: 8rpx;
  margin-right: 20rpx;
  background-color: #eee;
}

.product-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 140rpx;
}

.product-title {
  font-size: 26rpx; /* 13px */
  color: #121834;
  line-height: 1.4;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.product-value {
  font-size: 28rpx; /* 14px */
  color: #fa6400; /* Orange */
  font-weight: 500;
}

.product-tag {
  background-color: transparent;
  padding: 4rpx 10rpx;
  border-radius: 8rpx; /* 4px */
  border: 1rpx solid #e0e0e0;
}

.product-tag text {
  font-size: 22rpx; /* 11px */
  color: #a2b0b8;
}
