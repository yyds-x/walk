.page {
  min-height: 100vh;
  background: #F5F5F5;
}

/* ===== Header ===== */
.header {
  background: linear-gradient(180deg, #00C757 0%, #4CD964 100%);
  padding: 40rpx 40rpx 90rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.today-row {
  display: flex;
  align-items: baseline;
}

.today-amount {
  font-family: "DIN", "DIN Alternate", sans-serif;
  font-size: 80rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.today-unit {
  font-size: 32rpx;
  color: #FFFFFF;
  margin-left: 8rpx;
  font-weight: 500;
}

.today-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

/* ===== Stats Card ===== */
.stats-card {
  margin: -44rpx 32rpx 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  padding: 36rpx 0;
  position: relative;
  z-index: 2;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-family: "DIN", "DIN Alternate", sans-serif;
  font-size: 40rpx;
  font-weight: 700;
  color: #121834;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #EEEEEE;
}

/* ===== Menu Card ===== */
.menu-card {
  margin: 24rpx 32rpx 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 8rpx 0;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 36rpx;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
}

.menu-name {
  font-size: 30rpx;
  color: #121834;
  font-weight: 400;
}

.menu-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
}

/* ===== Banner ===== */
.banner {
  margin: 24rpx 32rpx 0;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 50%, #FFCC80 100%);
  padding: 32rpx;
}

.banner-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.banner-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.banner-person {
  width: 100rpx;
  height: 120rpx;
  position: relative;
}

.person-head {
  width: 48rpx;
  height: 48rpx;
  background: #5D4037;
  border-radius: 50%;
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
}

.person-body {
  width: 64rpx;
  height: 72rpx;
  background: #FFE0B2;
  border-radius: 32rpx 32rpx 8rpx 8rpx;
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  border: 2rpx solid #FFCC80;
}

.banner-text-col {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.banner-line1,
.banner-line2 {
  display: flex;
  align-items: center;
}

.banner-red {
  font-size: 40rpx;
  font-weight: 700;
  color: #E53935;
}

.banner-orange {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF8F00;
}

.banner-right {
  display: flex;
  align-items: center;
}

.banner-btn {
  background: linear-gradient(135deg, #FF6D00 0%, #FF3D00 100%);
  border-radius: 32rpx;
  padding: 16rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.banner-btn-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.banner-btn-arrow {
  font-size: 24rpx;
  color: #FFFFFF;
  width: 36rpx;
  height: 36rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-close {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 22rpx;
  color: #FFFFFF;
  line-height: 1;
}
