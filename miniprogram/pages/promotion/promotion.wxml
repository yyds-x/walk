<view class="page">
  <!-- Green header -->
  <view class="header">
    <view class="today-row">
      <text class="today-amount">{{todayIncomeDisplay}}</text>
      <text class="today-unit">元</text>
    </view>
    <text class="today-label">今日收益</text>
  </view>

  <!-- Stats card -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{totalIncome}}</text>
      <text class="stat-label">累计收益(元)</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{merchantCount}}</text>
      <text class="stat-label">商户数(个)</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{orderCount}}</text>
      <text class="stat-label">订单数(张)</text>
    </view>
  </view>

  <!-- Menu list -->
  <view class="menu-card">
    <view class="menu-item" wx:for="{{menuItems}}" wx:key="id" bindtap="onMenuTap" data-item="{{item}}">
      <view class="menu-left">
        <image class="menu-icon" src="{{item.icon}}" mode="aspectFit"></image>
        <text class="menu-name">{{item.name}}</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <!-- Banner -->
  <view class="banner" bindtap="onBannerTap">
    <view class="banner-inner">
      <view class="banner-left">
        <view class="banner-person">
          <view class="person-head"></view>
          <view class="person-body"></view>
        </view>
        <view class="banner-text-col">
          <view class="banner-line1">
            <text class="banner-red">自买</text>
            <text class="banner-orange"> 省钱</text>
          </view>
          <view class="banner-line2">
            <text class="banner-red">推广</text>
            <text class="banner-orange"> 赚钱</text>
          </view>
        </view>
      </view>
      <view class="banner-right">
        <view class="banner-btn">
          <text class="banner-btn-text">立即赚钱</text>
          <text class="banner-btn-arrow">></text>
        </view>
      </view>
    </view>
    <view class="banner-close" catchtap="closeBanner">
      <text class="close-icon">x</text>
    </view>
  </view>
</view>
