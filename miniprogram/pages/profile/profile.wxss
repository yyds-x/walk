.page {
  min-height: 100vh;
  background-color: #f4f4f4;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
}

.cell[open-type="chooseAvatar"] {
  width: 100%;
  box-sizing: border-box;
  margin: 0;
  background-color: transparent;
  border: none;
  text-align: left;
  line-height: normal;
  border-radius: 0;
}

.cell[open-type="chooseAvatar"]::after {
  border: none;
}

.cell-btn {
  width: 100%;
  box-sizing: border-box;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: transparent;
  text-align: left;
  line-height: normal;
  border-radius: 0;
}

.cell-btn::after {
  border: none;
}

.cell-left {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.cell-label {
  font-size: 32rpx;
  color: #111111;
}

.cell-right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  min-width: 0;
  flex: 1;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #f2f2f2;
}

.cell-input {
  flex: 1;
  min-width: 240rpx;
  text-align: right;
  font-size: 30rpx;
  color: #333333;
}

.cell-value {
  max-width: 420rpx;
  font-size: 30rpx;
  color: #888888;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cell-arrow {
  font-size: 34rpx;
  color: #c8c8c8;
  line-height: 1;
}

.divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin-left: 28rpx;
}

.logout-wrap {
  margin-top: 24rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.logout-btn {
  width: 100%;
  background-color: transparent;
  color: #ff4d4f;
  font-size: 32rpx;
  padding: 30rpx 0;
  line-height: 1;
}

.logout-btn::after {
  border: none;
}
